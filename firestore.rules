rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for authentication
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }
    
    function isAuthenticatedOrAnonymous() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'info@indiannaturalhair.com' ||
              request.auth.token.admin == true);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Public read access for products and config (for unauthenticated users)
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Allow service account access for sync and admin interface
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if true; // Allow admin interface access
    }
    
    // Allow public access for admin interface (consolidated salesmen rule)
    
    // Admin-only collections for data management
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /uploads/{uploadId} {
      allow read, write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    // User-specific collections - allow public read for admin dashboard stats
    match /clients/{clientId} {
      allow read: if true; // Allow public read for dashboard statistics
      allow write: if isAuthenticated();
    }
    
    match /quotes/{quoteId} {
      allow read, write: if true; // Allow public access for quotes functionality
    }

    match /orders/{orderId} {
      allow read, write: if true; // Allow public access for orders functionality
    }

    // Salespeople data - allow public access for admin interface
    match /salespeople/{salespersonId} {
      allow read, write: if true; // Allow public access for admin interface
    }
    
    // Colors collection - allow public read for admin dashboard stats
    match /colors/{colorId} {
      allow read: if true; // Allow public read for dashboard statistics
      allow write: if true; // Allow service account access for sync
    }
    
    // Styles collection - allow public read for admin dashboard stats
    match /styles/{styleId} {
      allow read: if true; // Allow public read for dashboard statistics
      allow write: if true; // Allow service account access for sync
    }
    
    // PriceLists collection - allow public read for shades and pricing data
    match /priceLists/{priceListId} {
      allow read: if true; // Allow public read for shades counting and pricing
      allow write: if true; // Allow service account access for sync
    }

    // Support lowercase pricelists collection used by some pages
    match /pricelists/{priceListId} {
      allow read: if true; // Allow public read for pricing dropdowns
      allow write: if true; // Allow service account/admin syncs
    }

    // Products collection access for diagnostics and legacy listeners
    match /products/{productId} {
      allow read: if true; // Enable real-time listener tests and legacy reads
      allow write: if true; // Allow service account/admin syncs
    }

    // INH Pricelists (legacy/canonical) - needed by list-categories.html and nested product data
    match /inh_pricelists/{docId} {
      allow read: if true;
      allow write: if true;

      // Nested subcollections commonly used by loaders and listeners
      match /categories/{catId} {
        allow read: if true;
        allow write: if true;
      }

      match /products/{prodId} {
        allow read: if true;
        allow write: if true;
      }

      match /densities/{densId} {
        allow read: if true;
        allow write: if true;
      }

      match /lengths/{lenId} {
        allow read: if true;
        allow write: if true;
      }
    }
    
    // INH Colors collection (new canonical)
    match /inh_colors/{colorId} {
      allow read: if true; // Allow public read for dropdowns and stats
      allow write: if true; // Allow service account/admin syncs
    }
    
    // INH Styles collection (new canonical)
    match /inh_styles/{styleId} {
      allow read: if true; // Allow public read for dropdowns and stats
      allow write: if true; // Allow service account/admin syncs
    }
    
    // INH Salesmen collection (new canonical)
    match /inh_salesmen/{salesmanId} {
      allow read: if true; // Allow public read for dropdowns
      allow write: if true; // Allow service account/admin syncs
    }
    
    // Sync logs - allow service account access
    match /sync_logs/{logId} {
      allow read, write: if true; // Allow service account access
    }
    
    // Storage collection for localStorage replacement
    match /storage/{storageId} {
      allow read, write: if true; // Allow public access for localStorage replacement
    }
    
    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Default deny for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}